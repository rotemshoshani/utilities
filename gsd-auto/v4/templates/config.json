{
  "version": 1,
  "session": {
    "tmuxSessionName": "gsd-auto-{project}",
    "claudeLaunchCommand": "claude --dangerously-skip-permissions --model {model}",
    "model": "claude-opus-4-6[1m]",
    "paneCaptureLines": 250,
    "pollIntervalSeconds": 5,
    "idleStabilityPolls": 3,
    "logLevel": "info",
    "logPerPollClassifier": false,
    "clearToMajorDelaySeconds": 1.5,
    "maxIdenticalMajorCommands": 2,
    "inputBoxScanLines": 5,
    "menuMaxNavigationSteps": 40,
    "menuKeyDelaySeconds": 0.1,
    "heartbeatIntervalSeconds": 300
  },
  "commands": {
    "clear": "/clear",
    "plan": {
      "withResearch": "/gsd-plan-phase {phase} --research --skip-ui --skip-bounce --text {verifyFlag} --prd {prd}",
      "withoutResearch": "/gsd-plan-phase {phase} --skip-research --skip-ui --skip-bounce --text {verifyFlag} --prd {prd}"
    },
    "execute": {
      "default": "/gsd-execute-phase {phase}"
    },
    "continue": "continue"
  },
  "project": {
    "prdPath": ".planning/ROADMAP.md"
  },
  "policy": {
    "defaultPlanMode": "without_research",
    "skipPlanVerification": true,
    "clearBeforeMajorCommand": true,
    "deferVerificationToMilestoneEnd": true,
    "verificationDeferralText": "defer to end of milestone verification",
    "allowLlmFallback": true,
    "llmFallbackAllowedTexts": [
      "continue",
      "y",
      "n",
      "yes",
      "no",
      "defer to end of milestone verification",
      "approve",
      "fix the bug now"
    ],
    "usageResetWaitMinutes": 15,
    "maxUsageResetAttempts": 32
  },
  "patterns": {
    "busyMarkers": [
      "esc to interrupt",
      "ctrl\\+b ctrl\\+b \\(twice\\) to run in background",
      "\\(\\d+m \\d+s · ",
      "thought for \\d+s",
      "\\d+ local agents? still running",
      "· \\d+ local agents?",
      "Backgrounded agent",
      "Waiting for completion notifications"
    ],
    "menuNavFooter": [
      "Enter to select",
      "↑/↓ to navigate",
      "Esc to cancel"
    ],
    "inputBoxBorderChars": ["╭", "╰", "│"],
    "usageLimitMenuOptions": [
      "Stop and wait for limit to reset",
      "Upgrade your plan"
    ],
    "waitForResetOption": [
      "Stop and wait for limit to reset"
    ],
    "verificationRequest": [
      "verification required",
      "please confirm",
      "manual UAT",
      "please test"
    ],
    "planningComplete": [
      "GSD ► PHASE (\\d+(?:\\.\\d+)?) PLANNED"
    ],
    "executionComplete": [
      "Phase (\\d+(?:\\.\\d+)?): .+ — Complete",
      "Pending items tracked"
    ],
    "nextPhaseAfterExecute": [
      "▶ Next Up — Phase (\\d+(?:\\.\\d+)?)"
    ]
  }
}
