    }


# ---------- Screen normalization ----------

ANSI_CSI_RE = re.compile(r"\x1B\[[0-?]*[ -/]*[@-~]")
ANSI_OSC_RE = re.compile(r"\x1B\][^\x07\x1B]*(?:\x07|\x1B\\)")
ANSI_OTHER_RE = re.compile(r"\x1B[@-Z\\\-_]")
MULTI_SPACE_RE = re.compile(r"[ \t]{2,}")


def strip_ansi(text: str) -> str:
    text = ANSI_CSI_RE.sub("", text)
    text = ANSI_OSC_RE.sub("", text)
    text = ANSI_OTHER_RE.sub("", text)
    return text


def normalize_screen(raw: str) -> str:
    s = strip_ansi(raw)
    s = s.replace("\r\n", "\n").replace("\r", "")
    out_lines = []
    for ln in s.split("\n"):
        ln = ln.replace("\t", " ")
        ln = MULTI_SPACE_RE.sub(" ", ln)
        ln = ln.rstrip()
        out_lines.append(ln)
    return "\n".join(out_lines).strip("\n")


def screen_hash(normalized: str) -> str:
    return hashlib.sha256(normalized.encode("utf-8", errors="replace")).hexdigest()[:16]


def has_input_box(normalized: str, scan_lines: int = DEFAULT_INPUT_BOX_SCAN_LINES) -> bool:
    """Detect Claude's input-box in either idle or busy rendering.

    Idle state renders the input as a rounded box (╭─╮ / ╰─╯) with the prompt ❯
    inside. Busy state collapses the box into two long horizontal rules (─×N)
    sandwiching a ❯ line — same input area, different chrome.

    Detection (within the last `scan_lines` rows):
      1. corner-glyph pair: ╰ and ╯ on one line, or ╭ and ╮ on one line — idle.
      2. busy fallback: a ❯-prefixed prompt line plus at least one
         long horizontal-rule line (≥50 ─ characters) within the window.

    The bare vertical bar │ is intentionally not used: it appears constantly in
    tool-call boxes, tables, and agent output and produces false positives.
    The 50-char rule threshold avoids matching table separators (typically
    interrupted by ┼/┬/┴) and short divider glyphs in lists or summaries.
    """
    if scan_lines <= 0:
        return False
    lines = normalized.split("\n")[-scan_lines:]
    for ln in lines:
        if ("╰" in ln and "╯" in ln) or ("╭" in ln and "╮" in ln):
            return True
    has_prompt = any(ln.lstrip().startswith("❯") for ln in lines)
    has_long_rule = any(ln.count("─") >= 50 for ln in lines)
    return has_prompt and has_long_rule


# ---------- Classifier ----------

class Classifier(enum.Enum):
    BUSY = "busy"
    IDLE = "idle"
    MENU = "menu"
    TEXT_PROMPT = "text-prompt"
    USAGE_LIMITED = "usage-limited"


def match_patterns(text: str, patterns: list[str], ignore_case: bool = True) -> list[str]:
    out = []
    flags = re.IGNORECASE if ignore_case else 0
    for p in patterns:
        try:
            if re.search(p, text, flags):
                out.append(p)
        except re.error:
            t = text.lower() if ignore_case else text
            n = p.lower() if ignore_case else p
            if n in t:
                out.append(p)
    return out


RATE_LIMIT_TAIL_LINES = 60


def _flatten_tail(normalized: str, n_lines: int) -> str:
    """Return the last n_lines of normalized output with all whitespace
    (including newlines) collapsed to single spaces.

    This makes pattern matching robust against terminal line-wrapping: a menu
    option like "Stop and wait for limit to reset" that gets wrapped across
    two rows in a narrow pane will still match. We confine to the live tail
    so stale scrollback can't fire false positives forever after dismissal.
    """
    tail = "\n".join(normalized.split("\n")[-n_lines:]) if n_lines > 0 else normalized
    return re.sub(r"\s+", " ", tail)


def classify(
    normalized: str,
    hash_unstable: bool,
    patterns: dict,
    input_box_scan_lines: int = DEFAULT_INPUT_BOX_SCAN_LINES,
    busy_marker_scan_lines: int = DEFAULT_BUSY_MARKER_SCAN_LINES,
) -> tuple[Classifier, dict]:
    info: dict = {"matched": []}

    # 0. USAGE_LIMITED first — even before BUSY, in two flavors:
    #
    #    (a) Blocking rate-limit MENU. "Stop and wait for limit to reset" etc.
    #        is unambiguous and does not appear in normal busy output. Above
    #        BUSY/hash_unstable so lingering busy markers or cursor flicker
    #        can't suppress detection.
    #
    #    (b) Inline SUBAGENT rate-limit text. When a subagent hits the cap,
    #        Claude Code prints inline tool output (no menu):
    #           ⎿  You've hit your limit · resets 1pm
    #              /upgrade or /extra-usage to finish what you're working on.
    #        Critically, Claude Code's UI may keep "1 local agent still
    #        running" visible while the subagent dies — meaning busyMarkers
    #        match at the same time as the inline text. Putting inline below
    #        BUSY would mis-classify these dying-subagent transients as
    #        active work and miss the limit. So inline lives above BUSY too;
    #        the WAITING_FOR_RESET timer prevents re-firing thrash.
    #
    #    We match a whitespace-flattened tail so narrow-pane line-wrapping does
    #    not break the regex, and we treat ANY one of the configured signature
    #    patterns as sufficient (1-of-N) so wording drift on one option does
    #    not require all options to match.
    usage_opts = patterns.get("usageLimitMenuOptions", [])
    if usage_opts:
        flat_tail = _flatten_tail(normalized, RATE_LIMIT_TAIL_LINES)
        usage_hits = match_patterns(flat_tail, usage_opts)
        if usage_hits:
            info["matched"] = usage_hits
            info["hashUnstable"] = hash_unstable
            info["source"] = "flattened-tail-menu"
            return Classifier.USAGE_LIMITED, info

    inline_markers = patterns.get("usageLimitInlineMarkers", [])
    if inline_markers:
        flat_tail = _flatten_tail(normalized, RATE_LIMIT_TAIL_LINES)
        inline_hits = match_patterns(flat_tail, inline_markers)
        if inline_hits:
            info["matched"] = inline_hits
            info["inline"] = True
            info["hashUnstable"] = hash_unstable
            info["source"] = "flattened-tail-inline"
            return Classifier.USAGE_LIMITED, info

    # 1. BUSY. Active work takes precedence over the remaining classifications —
    #    including soft "approaching limit" warnings that may be visible inline
    #    while Claude is still working.
    #    Scan only the live tail of the pane: active busy indicators
    #    ("esc to interrupt", spinner timer, "ctrl+b ctrl+b twice to background",
    #    "Waiting for completion notifications") are always rendered immediately
    #    above the input box. Matching against full scrollback wedges the
    #    classifier on stale text from completed tool output.
    busy_window = "\n".join(normalized.split("\n")[-busy_marker_scan_lines:]) \
        if busy_marker_scan_lines > 0 else normalized
    busy_m = match_patterns(busy_window, patterns.get("busyMarkers", []))
    if busy_m or hash_unstable:
        info["matched"] = busy_m
        info["hashUnstable"] = hash_unstable
        return Classifier.BUSY, info

    # 2. Menu-state detection. Without an input box rendered (or with the menu
    #    nav footer visible) the screen is presenting a blocking choice.
    has_box = has_input_box(normalized, input_box_scan_lines)
    info["hasInputBox"] = has_box
    menu_footer = match_patterns(normalized, patterns.get("menuNavFooter", []))
    is_menu_up = (not has_box) or bool(menu_footer)

    if is_menu_up:
        info["matched"] = menu_footer
        return Classifier.MENU, info

    # 3. Free-text prompts (verification etc.) — input box present but no
    #    busy markers and no menu state.
    vrf_m = match_patterns(normalized, patterns.get("verificationRequest", []))
    if vrf_m:
        info["matched"] = vrf_m
        return Classifier.TEXT_PROMPT, info

    return Classifier.IDLE, info


# ---------- State ----------

class State(enum.Enum):
    BOOT = "BOOT"
    SESSION_STARTING = "SESSION_STARTING"
    RUNNING = "RUNNING"
    DECISION_REQUIRED = "DECISION_REQUIRED"
    INTERACTIVE_MENU = "INTERACTIVE_MENU"
    TEXT_PROMPT = "TEXT_PROMPT"
    USAGE_LIMITED = "USAGE_LIMITED"
    WAITING_FOR_RESET = "WAITING_FOR_RESET"
    PAUSED_FOR_HUMAN = "PAUSED_FOR_HUMAN"
    COMPLETE = "COMPLETE"
    ERROR = "ERROR"


@dataclasses.dataclass
class RuntimeState:
    state: str = State.BOOT.value
    hasObservedFirstCycle: bool = False
    lastPhase: str | None = None
    lastCommandSent: str | None = None
    lastActionTimestamp: str | None = None
    retryCounts: dict = dataclasses.field(default_factory=dict)
    usageResetAttempts: int = 0
    lastMenuSnapshot: dict | None = None
    screenHash: str | None = None
    stableCount: int = 0
    pollCount: int = 0
    waitingResetUntil: str | None = None

    def to_json(self) -> dict:
        return dataclasses.asdict(self)

    @classmethod
    def from_json(cls, data: dict) -> "RuntimeState":
        names = {f.name for f in dataclasses.fields(cls)}
        return cls(**{k: v for k, v in data.items() if k in names})


# ---------- Tmux ----------

class Tmux:
    def __init__(self, session: str):
        self.session = session
        self._main_pane: str | None = None

    def has_session(self) -> bool:
        try:
            r = subprocess.run(
                ["tmux", "has-session", "-t", self.session],
                capture_output=True, timeout=TMUX_TIMEOUT_SECONDS,
            )
        except subprocess.TimeoutExpired:
            return False
        return r.returncode == 0

    def new_session(self, command: str | None = None) -> None:
        args = ["tmux", "new-session", "-d", "-s", self.session]
        if command:
            args.append(command)
        subprocess.run(args, check=True, timeout=TMUX_TIMEOUT_SECONDS)

    def main_pane(self) -> str:
        if self._main_pane:
            return self._main_pane
        r = subprocess.run(
            ["tmux", "list-panes", "-t", self.session, "-F", "#{pane_id}"],
            check=True, capture_output=True, text=True,
            timeout=TMUX_TIMEOUT_SECONDS,
        )
        panes = [ln.strip() for ln in r.stdout.splitlines() if ln.strip()]
        self._main_pane = panes[0] if panes else self.session
        return self._main_pane

    def capture_pane(self, lines: int) -> str:
        r = subprocess.run(
            ["tmux", "capture-pane", "-t", self.main_pane(), "-p", "-e", "-J", "-S", f"-{lines}"],
            capture_output=True, text=True, errors="replace",
            timeout=TMUX_TIMEOUT_SECONDS,
        )
        return r.stdout

    def send_keys(self, *keys: str) -> None:
        subprocess.run(
            ["tmux", "send-keys", "-t", self.main_pane(), *keys],
            check=True, timeout=TMUX_TIMEOUT_SECONDS,
        )

    def send_text_enter(self, text: str) -> None:
        subprocess.run(
            ["tmux", "send-keys", "-t", self.main_pane(), text, "Enter"],
            check=True, timeout=TMUX_TIMEOUT_SECONDS,
        )

    def split_window(self, *, target: str, cwd: pathlib.Path, command: str,
                     horizontal: bool = False, percent: int | None = None) -> str:
        args = ["tmux", "split-window"]
        if horizontal:
            args.append("-h")
        if percent is not None:
            args.extend(["-p", str(percent)])
        args.extend(["-t", target, "-c", str(cwd), "-P", "-F", "#{pane_id}", command])
        r = subprocess.run(
            args, check=True, capture_output=True, text=True,
            timeout=TMUX_TIMEOUT_SECONDS,
        )
        return r.stdout.strip()

    def select_main_pane(self) -> None:
        subprocess.run(
            ["tmux", "select-pane", "-t", self.main_pane()],
            check=True, timeout=TMUX_TIMEOUT_SECONDS,
        )


# ---------- Decision policy ----------

def render_command(template: str, *, phase: str | None = None,
                   prd: str | None = None, project: str | None = None,
                   verify_flag: str | None = None) -> str:
    out = template
    if phase is not None:
        out = out.replace("{phase}", phase)
    if prd is not None:
        out = out.replace("{prd}", prd)
    if project is not None:
        out = out.replace("{project}", project)
    if verify_flag is not None:
        out = out.replace("{verifyFlag}", verify_flag)
    out = re.sub(r"  +", " ", out).strip()
    return out


def steady_state_decision(normalized: str, config: dict) -> dict | None:
    patterns = config["patterns"]

    for pat in patterns.get("planningComplete", []):
        try:
            m = re.search(pat, normalized)
        except re.error:
            continue
        if m:
            phase = m.group(1) if m.groups() else None
            return {"rule": "planningComplete", "phase": phase, "next": "execute"}

    exec_match = None
    for pat in patterns.get("executionComplete", []):
        try:
            m = re.search(pat, normalized)
        except re.error:
            continue
        if m:
            exec_match = m
            break

    if exec_match:
        next_phase = None
        for pat in patterns.get("nextPhaseAfterExecute", []):
            try:
                m = re.search(pat, normalized)
            except re.error:
                continue
            if m and m.groups():
                next_phase = m.group(1)
                break
        if next_phase:
            return {
                "rule": "executionComplete+nextPhase",
                "phase": next_phase,
                "next": "plan",
            }
        return {"rule": "executionComplete+noNext", "next": "complete"}

    return None


# ---------- Controller ----------

class Controller:
    def __init__(self, repo: pathlib.Path, config: dict):
        self.repo = repo
        self.config = config
        self.paths = runtime_paths(repo)
        self.session_name = config["session"]["tmuxSessionName"].replace("{project}", repo.name)
        self.tmux = Tmux(self.session_name)
        self.state = self._load_state()
        self.logger = self._setup_logger()
        self.last_hash: str | None = self.state.screenHash
        self.stable_count = self.state.stableCount or 0

        # Tunables read once at start; do not re-read each call.
        sess = config["session"]
        self.clear_to_major_delay = float(sess.get("clearToMajorDelaySeconds", DEFAULT_CLEAR_TO_MAJOR_DELAY))
        self.max_identical_major = int(sess.get("maxIdenticalMajorCommands", DEFAULT_MAX_IDENTICAL_MAJOR))
        self.input_box_scan_lines = int(sess.get("inputBoxScanLines", DEFAULT_INPUT_BOX_SCAN_LINES))
        self.busy_marker_scan_lines = int(sess.get("busyMarkerScanLines", DEFAULT_BUSY_MARKER_SCAN_LINES))
        self.menu_max_nav_steps = int(sess.get("menuMaxNavigationSteps", DEFAULT_MENU_MAX_NAV_STEPS))
        self.menu_key_delay = float(sess.get("menuKeyDelaySeconds", DEFAULT_MENU_KEY_DELAY))
        self.heartbeat_interval = float(sess.get("heartbeatIntervalSeconds", 300))

        # Per-run signals for liveness logging
        self.last_classifier: str | None = None
        self.last_heartbeat_at: float = 0.0
        self.last_near_miss_warn_at: float = 0.0

        # LLM fallback cache + staircase.
        #
        # The fallback fires on every IDLE-stable poll when no deterministic
        # rule matches. On a long static screen that's one API call per poll
        # (5s) — real money. Two-layer protection:
        #
        # (1) Hash cache: once Haiku says "wait" on a given screen hash,
        #     subsequent polls reuse the decision until something on screen
        #     changes (or escalation kicks in).
        #
        # (2) Staircase: per static-screen hash, allow up to N API calls
        #     total. After ESCALATION_POLLS cache hits, invalidate cache and
        #     re-call Haiku with MORE pane context (deeper scrollback +
        #     longer prompt window) — it might catch something it missed at
        #     the smaller window. After the cap is exhausted, stay in cached
        #     wait permanently to prevent runaway cost.
        self.llm_cache_hash: str | None = None
        self.llm_cache_was_wait: bool = False
        self.llm_cache_at: float = 0.0
        self.llm_cache_hits: int = 0
        self.llm_static_hash: str | None = None
        self.llm_static_calls: int = 0
        # Transient-error cooldown: skip API calls until this timestamp.
        self.llm_error_cooldown_until: float = 0.0

    def _log_level(self) -> int:
        return {
            "debug": logging.DEBUG,
            "info": logging.INFO,
            "warn": logging.WARNING,
            "warning": logging.WARNING,
            "error": logging.ERROR,
        }.get(self.config["session"].get("logLevel", "info").lower(), logging.INFO)

    def _setup_logger(self) -> logging.Logger:
        logger = logging.getLogger("gsd-auto-v4")
        logger.handlers.clear()
        logger.setLevel(self._log_level())
        fh = logging.FileHandler(self.paths["log"])
        fh.setLevel(self._log_level())
        fh.setFormatter(logging.Formatter(
            "[%(asctime)s] [%(levelname)s] %(message)s",
            "%Y-%m-%d %H:%M:%S",
        ))
        logger.addHandler(fh)
        logger.propagate = False
        return logger

    def _load_state(self) -> RuntimeState:
        if self.paths["state"].exists():
            try:
                return RuntimeState.from_json(json.loads(self.paths["state"].read_text()))
            except (json.JSONDecodeError, TypeError):
                pass
        return RuntimeState()

    def _save_state(self) -> None:
        self.paths["state"].write_text(json.dumps(self.state.to_json(), indent=2))

    def _emit_event(self, **fields) -> None:
        fields["timestamp"] = dt.datetime.now().isoformat()
        with self.paths["events"].open("a") as f:
            f.write(json.dumps(fields) + "\n")

    def _emit_action(self, **fields) -> None:
        fields["timestamp"] = dt.datetime.now().isoformat()
        with self.paths["actions"].open("a") as f:
            f.write(json.dumps(fields) + "\n")

    def _transition(self, new_state: State, *, reason: str = "") -> None:
        old = self.state.state
        new = new_state.value
        if old != new:
            self.logger.info(f"state: {old} -> {new} ({reason})")
            self._emit_event(prevState=old, newState=new, reason=reason)
        self.state.state = new
        self._save_state()

    def run(self) -> None:
        try:
            self._main_loop()
        except KeyboardInterrupt:
            self.logger.info("interrupted")
        except Exception:
            self.logger.exception("fatal controller error")
            self.state.state = State.ERROR.value
            self._save_state()
        finally:
            try:
                self.paths["pid"].unlink()
            except FileNotFoundError:
                pass

    def _main_loop(self) -> None:
        self.logger.info(
            f"controller start: project={self.repo.name} session={self.session_name} "
            f"config={self.repo / CONFIG_REL} logLevel={self.config['session'].get('logLevel','info')}"
        )

        # If the persisted state.json says the previous run ended in a terminal
        # state (COMPLETE or ERROR), treat this fresh `run` as a new workflow
        # rather than exiting immediately. Without this, completing a milestone
        # leaves state.json in COMPLETE forever and every subsequent `run`
        # silently no-ops the moment the main loop's while-condition is checked.
        if self.state.state in (State.COMPLETE.value, State.ERROR.value):
            prev = self.state.state
            self.state = RuntimeState()
            self._save_state()
            self.logger.info(f"previous run ended in {prev}; resetting state to BOOT")

        # If the previous run got stuck in PAUSED_FOR_HUMAN, restarting the
        # controller is an implicit "I'm back, retry". Without this, the only
        # way out of PAUSED_FOR_HUMAN is a BUSY classifier blip, which never
        # arrives if Claude itself is sitting idle — leading to overnight
        # strandings exactly like the inputBoxScanLines=5 false-menu bug.
        # We keep all other state (lastPhase, retryCounts, etc.) intact.
        if self.state.state == State.PAUSED_FOR_HUMAN.value:
            self.state.state = State.RUNNING.value
            self._save_state()
            self.logger.info("previous run was PAUSED_FOR_HUMAN; resuming on restart")

        if self.state.state == State.BOOT.value:
            self._transition(State.SESSION_STARTING, reason="boot")
        if self.state.state == State.SESSION_STARTING.value:
            self._transition(State.RUNNING, reason="session brought up")

        poll_interval = float(self.config["session"]["pollIntervalSeconds"])
        capture_lines = int(self.config["session"]["paneCaptureLines"])
        idle_stability = int(self.config["session"]["idleStabilityPolls"])
        log_per_poll = bool(self.config["session"].get("logPerPollClassifier", False))

        while self.state.state not in (State.COMPLETE.value, State.ERROR.value):
            self.state.pollCount += 1

            try:
                raw = self.tmux.capture_pane(capture_lines)
            except (subprocess.CalledProcessError, subprocess.TimeoutExpired) as e:
                self.logger.error(f"tmux capture failed: {e}")
                time.sleep(poll_interval)
                continue

            normalized = normalize_screen(raw)
            cur_hash = screen_hash(normalized)

            if self.last_hash is None:
                unstable = False
                self.stable_count = 1
            elif cur_hash == self.last_hash:
                unstable = False
                self.stable_count += 1
            else:
                unstable = True
                self.stable_count = 1

            try:
                self.paths["raw"].write_text(raw)
                self.paths["norm"].write_text(normalized)
            except OSError as e:
                self.logger.error(f"failed to persist screen: {e}")

            self.state.screenHash = cur_hash
            self.state.stableCount = self.stable_count
            self.last_hash = cur_hash

            classifier, info = classify(
                normalized, unstable, self.config["patterns"],
                input_box_scan_lines=self.input_box_scan_lines,
                busy_marker_scan_lines=self.busy_marker_scan_lines,
            )

            self.logger.debug(
                f"poll #{self.state.pollCount}: lines={normalized.count(chr(10))+1} "
                f"hash={cur_hash} classifier={classifier.value} stable={self.stable_count}"
            )
            if log_per_poll:
                self.logger.info(
                    f"poll #{self.state.pollCount}: classifier={classifier.value} "
                    f"matched={info.get('matched')}"
                )

            # Classifier-change line: log when the per-poll classification flips.
            # Catches BUSY→IDLE (Claude finished a step), IDLE→BUSY (started), and
            # any USAGE_LIMITED/MENU/TEXT_PROMPT entry/exit. One line per change,
            # not per poll, so it stays readable during long busy stretches.
            if classifier.value != self.last_classifier:
                matched = info.get("matched") or []
                tail = f" matched={matched}" if matched else ""
                from_label = self.last_classifier or "?"
                self.logger.info(
                    f"classifier: {from_label} -> {classifier.value}{tail}"
                )
                self.last_classifier = classifier.value

            now_ts = time.time()

            # Rate-limit near-miss diagnostic: rate-limit menu text appears in
            # the live tail but classifier did NOT fire USAGE_LIMITED. This is
            # the exact failure mode that strands the controller overnight —
            # the menu is up but we don't act on it. Log loudly so post-hoc
            # log review can confirm the cause. Throttled to once per 60s to
            # avoid flooding when stale text lingers in scrollback.
            if classifier != Classifier.USAGE_LIMITED:
                tail_for_warn = "\n".join(normalized.split("\n")[-RATE_LIMIT_TAIL_LINES:])
                if re.search(r"stop and wait|limit to reset|usage limit reached",
                             tail_for_warn, re.IGNORECASE):
                    if now_ts - self.last_near_miss_warn_at >= 60:
                        self.last_near_miss_warn_at = now_ts
                        snippet = re.sub(r"\s+", " ", tail_for_warn)[-300:]
                        self.logger.warning(
                            f"rate-limit near-miss: classifier={classifier.value} "
                            f"info={info} tail_snippet={snippet!r}"
                        )

            # Heartbeat: emit a status summary every heartbeat_interval seconds even
            # if nothing changed. Without this, the log can go silent for hours
            # during busy phases and you can't tell if the controller is alive.
            if now_ts - self.last_heartbeat_at >= self.heartbeat_interval:
                last_action = self.state.lastActionTimestamp
                if last_action:
                    try:
                        last_dt = dt.datetime.fromisoformat(last_action)
                        ago_s = int((dt.datetime.now() - last_dt).total_seconds())
                        h, rem = divmod(ago_s, 3600)
                        m, s = divmod(rem, 60)
                        ago = f"{h}h{m:02d}m" if h else (f"{m}m{s:02d}s" if m else f"{s}s")
                    except (ValueError, TypeError):
                        ago = "?"
                else:
                    ago = "never"
                self.logger.info(
                    f"heartbeat: poll=#{self.state.pollCount} state={self.state.state} "
                    f"classifier={classifier.value} stable={self.stable_count} "
                    f"lastAction={ago}"
                )
                self.last_heartbeat_at = now_ts

            paused = self.paths["pause_flag"].exists()
            if not paused:
                try:
                    self._step(classifier, info, normalized, idle_stability)
                except Exception:
                    self.logger.exception("error in step handler")

            self._save_state()
            time.sleep(poll_interval)

    def _step(self, classifier: Classifier, info: dict,
              normalized: str, idle_stability: int) -> None:
        if classifier == Classifier.BUSY and not self.state.hasObservedFirstCycle:
            self.state.hasObservedFirstCycle = True
            self.logger.info("observed first busy cycle; entering steady-state mode")

        cur = State(self.state.state)

        if cur == State.PAUSED_FOR_HUMAN:
            if classifier == Classifier.BUSY:
                self._transition(State.RUNNING, reason="human activity detected; resuming")
            return

        if cur == State.WAITING_FOR_RESET:
            self._handle_waiting_for_reset(classifier, normalized)
            return

        # All other live states route through the same dispatcher; it re-classifies
        # and either acts or transitions to a terminal/paused state.
        self._dispatch(classifier, info, normalized, idle_stability)

    def _dispatch(self, classifier: Classifier, info: dict,
                  normalized: str, idle_stability: int) -> None:
        if classifier == Classifier.BUSY:
            if self.state.state != State.RUNNING.value:
                self._transition(State.RUNNING, reason="busy observed")
            return

        if classifier == Classifier.USAGE_LIMITED:
            self._transition(State.USAGE_LIMITED, reason=f"usage limit detected ({info.get('matched')})")
            self._handle_usage_limited(normalized, info)
            return

        if classifier == Classifier.MENU:
            self._transition(State.INTERACTIVE_MENU, reason=f"menu detected (footer={info.get('matched')}, hasInputBox={info.get('hasInputBox')})")
            self._handle_menu(normalized)
            return

        if classifier == Classifier.TEXT_PROMPT:
            self._transition(State.TEXT_PROMPT, reason=f"text prompt detected ({info.get('matched')})")
            self._handle_text_prompt(normalized)
            return

        # IDLE
        if not self.state.hasObservedFirstCycle:
            self.logger.debug("idle pre-bootstrap; waiting for human first command")
            return

        if self.stable_count < idle_stability:
            self.logger.debug(f"idle stable {self.stable_count}/{idle_stability}; waiting")
            return

        self.logger.info(
            f"poll #{self.state.pollCount}: classifier=idle "
            f"(hash stable {self.stable_count}/{idle_stability}) → DECISION_REQUIRED"
        )
        self._transition(State.DECISION_REQUIRED, reason=f"idle stable {self.stable_count}")
        self._handle_decision(normalized)

    def _handle_decision(self, normalized: str) -> None:
        if self.paths["stop_next_flag"].exists():
            self.logger.warning("stop-next.flag present; transitioning to COMPLETE")
            self._transition(State.COMPLETE, reason="stop-next requested by user")
            return

        decision = steady_state_decision(normalized, self.config)
        if decision is None:
            if self.config["policy"].get("allowLlmFallback"):
                self._try_llm_fallback(normalized)
                return
            self.logger.warning("no deterministic rule matched at idle; pausing for human")
            self._transition(State.PAUSED_FOR_HUMAN, reason="ambiguous_idle")
            return

        self.logger.info(
            f"decision: {decision['rule']} matched, phase={decision.get('phase')}, "
            f"action={decision.get('next')}"
        )
        self._emit_event(decision=decision)

        if decision["next"] == "complete":
            self.logger.info("milestone boundary detected; no next phase. COMPLETE")
            self._transition(State.COMPLETE, reason="execution complete and no next phase")
            return

        phase = decision.get("phase")
        if not phase:
            self.logger.warning("decision missing phase; pausing")
            self._transition(State.PAUSED_FOR_HUMAN, reason="phase extraction failed")
            return

        self.state.lastPhase = phase

        if decision["next"] == "execute":
            tmpl = self.config["commands"]["execute"]["default"]
            self._send_major_command(tmpl, phase=phase)
        elif decision["next"] == "plan":
            mode = self.config["policy"].get("defaultPlanMode", "without_research")
            tmpl_key = "withResearch" if mode == "with_research" else "withoutResearch"
            tmpl = self.config["commands"]["plan"][tmpl_key]
            prd = self.config["project"].get("prdPath", "")
            skip_verify = bool(self.config["policy"].get("skipPlanVerification", False))
            verify_flag = "--skip-verify" if skip_verify else ""
            self._send_major_command(tmpl, phase=phase, prd=prd, verify_flag=verify_flag)
        else:
            self.logger.warning(f"unknown decision.next={decision['next']}; pausing")
            self._transition(State.PAUSED_FOR_HUMAN, reason="unknown decision branch")
            return

        self._transition(State.RUNNING, reason="action sent")

    def _send_major_command(self, template: str, *, phase: str, prd: str = "",
                             verify_flag: str = "") -> None:
        if self.paths["stop_next_flag"].exists():
            self.logger.warning("stop-next requested; refusing to send major command")
            self._transition(State.COMPLETE, reason="stop-next")
            return

        cmd = render_command(template, phase=phase, prd=prd,
                             project=self.repo.name, verify_flag=verify_flag)

        if cmd == self.state.lastCommandSent:
            self.state.retryCounts["sameMajor"] = self.state.retryCounts.get("sameMajor", 0) + 1
            count = self.state.retryCounts["sameMajor"]
            self.logger.warning(
                f"about to send identical major command (count={count}/{self.max_identical_major}): {cmd}"
            )
            if count >= self.max_identical_major:
                self.logger.error("identical major command threshold exceeded; pausing")
                self._transition(State.PAUSED_FOR_HUMAN, reason="repeated identical major command")
                return
        else:
            self.state.retryCounts["sameMajor"] = 0

        if self.config["policy"].get("clearBeforeMajorCommand", True):
            clear_cmd = self.config["commands"].get("clear", "/clear")
            self._send_text(clear_cmd)
            time.sleep(self.clear_to_major_delay)

        self._send_text(cmd)
        self.state.lastCommandSent = cmd
        self.stable_count = 0
        self.state.stableCount = 0

    def _send_text(self, text: str) -> None:
        self.logger.info(f"action: tmux send-keys '{text}' Enter")
        try:
            self.tmux.send_text_enter(text)
        except (subprocess.CalledProcessError, subprocess.TimeoutExpired) as e:
            self.state.retryCounts["sendFailures"] = self.state.retryCounts.get("sendFailures", 0) + 1
            self.logger.error(
                f"send-keys failed (count={self.state.retryCounts['sendFailures']}): {e}"
            )
            self._transition(State.PAUSED_FOR_HUMAN, reason=f"send-keys failed: {e}")
            return
        self.state.retryCounts["sendFailures"] = 0
        self.state.lastActionTimestamp = dt.datetime.now().isoformat()
        self._emit_action(kind="text", text=text)

    def _handle_menu(self, normalized: str) -> None:
        wait_opts = self.config["patterns"].get("waitForResetOption", [])
        for opt in wait_opts:
            if re.search(opt, normalized, re.IGNORECASE):
                self.logger.info(f"menu: recognized usage-reset option '{opt}'")
                self._navigate_to_option(normalized, opt)
                return
        self.logger.warning("menu: no recognized rule; pausing")
        self._transition(State.PAUSED_FOR_HUMAN, reason="unrecognized menu")

    def _navigate_to_option(self, normalized: str, target_pattern: str) -> None:
        lines = normalized.split("\n")
        # Scan BOTTOM-UP. Menus always render at the bottom of the terminal,
        # and the input box ❯ prompt of whatever the user typed to invoke the
        # menu (e.g. `❯ /rate-limit-options`) usually still sits visible
        # ABOVE the menu region. A top-down scan for ❯ would lock onto that
        # prompt and produce a wildly wrong cursor distance — leading to
        # wrap-around and the wrong option being selected (e.g. Upgrade
        # instead of Wait). Bottom-up reliably finds the menu's own cursor
        # and the menu-option line for the target pattern.
        cursor_idx = None
        target_idx = None
        for i in range(len(lines) - 1, -1, -1):
            if cursor_idx is None and "❯" in lines[i]:
                cursor_idx = i
            if target_idx is None and re.search(target_pattern, lines[i], re.IGNORECASE):
                target_idx = i
            if cursor_idx is not None and target_idx is not None:
                break

        if cursor_idx is None or target_idx is None:
            self.logger.warning(
                f"menu navigation: cursor={cursor_idx} target={target_idx}; pausing"
            )
            self._transition(State.PAUSED_FOR_HUMAN, reason="menu navigation failed")
            return

        diff = target_idx - cursor_idx
        if abs(diff) > self.menu_max_nav_steps:
            self.logger.warning(
                f"menu navigation: distance {diff} exceeds {self.menu_max_nav_steps}; pausing"
            )
            self._transition(State.PAUSED_FOR_HUMAN, reason="menu distance too large")
            return

        key = "Down" if diff > 0 else "Up"
        steps = abs(diff)
        if steps > 0:
            self.logger.info(f"menu: navigating cursor {cursor_idx} -> target {target_idx} ({key} x{steps})")
            for _ in range(steps):
                try:
                    self.tmux.send_keys(key)
                except (subprocess.CalledProcessError, subprocess.TimeoutExpired) as e:
                    self.logger.error(f"menu nav send-keys '{key}' failed: {e}")
                    self._transition(State.PAUSED_FOR_HUMAN, reason=f"menu nav send-keys failed: {e}")
                    return
                self._emit_action(kind="key", text=key)
                time.sleep(self.menu_key_delay)

        self.logger.info("menu: confirming with Enter")
        try:
            self.tmux.send_keys("Enter")
        except (subprocess.CalledProcessError, subprocess.TimeoutExpired) as e:
            self.logger.error(f"menu confirm send-keys 'Enter' failed: {e}")
            self._transition(State.PAUSED_FOR_HUMAN, reason=f"menu confirm send-keys failed: {e}")
            return
        self._emit_action(kind="key", text="Enter")

        wait_min = self.config["policy"].get("usageResetWaitMinutes", 15)
        self.state.usageResetAttempts += 1
        self.state.waitingResetUntil = (
            dt.datetime.now() + dt.timedelta(minutes=wait_min)
        ).isoformat()
        self._transition(State.WAITING_FOR_RESET, reason=f"selected reset option: {target_pattern}")

    def _handle_text_prompt(self, normalized: str) -> None:
        if self.config["policy"].get("deferVerificationToMilestoneEnd"):
            for p in self.config["patterns"].get("verificationRequest", []):
                if re.search(p, normalized, re.IGNORECASE):
                    text = self.config["policy"].get(
                        "verificationDeferralText",
                        "defer to end of milestone verification",
                    )
                    self._send_text(text)
                    self._transition(State.RUNNING, reason="verification deferred")
                    return

        if self.config["policy"].get("allowLlmFallback"):
            self._try_llm_fallback(normalized)
            return

        self.logger.warning("text prompt: no rule matched; pausing")
        self._transition(State.PAUSED_FOR_HUMAN, reason="unrecognized text prompt")

    def _handle_usage_limited(self, normalized: str, info: dict) -> None:
        max_attempts = int(self.config["policy"].get("maxUsageResetAttempts", 32))
        if self.state.usageResetAttempts >= max_attempts:
            self.logger.error(f"max usage reset attempts ({max_attempts}) exhausted; pausing")
            self._transition(State.PAUSED_FOR_HUMAN, reason="usage reset attempts exhausted")
            return

        if info.get("inline"):
            # Inline subagent rate-limit: no menu to dismiss; the input box is
            # live and Claude is awaiting input. Send "continue" to nudge it,
            # then enter the same WAITING_FOR_RESET 15-min retry loop the menu
            # path uses.
            cont = self.config["commands"].get("continue", "continue")
            self.logger.info(f"inline usage-limit detected; sending '{cont}'")
            try:
                self._send_text(cont)
            except (subprocess.CalledProcessError, subprocess.TimeoutExpired) as e:
                self.logger.error(f"inline usage-limit send-text failed: {e}")
                self._transition(State.PAUSED_FOR_HUMAN, reason=f"send-text failed: {e}")
                return
            transition_reason = "inline usage-limit; sent continue"
        else:
            # The Claude Code rate-limit menu always presents "Stop and wait
            # for limit to reset" as option 1 with the cursor pre-selected on
            # it. Just press Enter — no cursor detection or arrow-key
            # navigation needed. This avoids an entire class of menu-
            # navigation bugs that otherwise show up when the input prompt's
            # ❯ confuses cursor scans. If Claude Code ever changes the default
            # option order, the worst case is we accidentally select Upgrade
            # once and the user notices — far better than the convoluted
            # scan-and-jump logic.
            self.logger.info("usage-limit menu detected; pressing Enter on default option")
            try:
                self.tmux.send_keys("Enter")
            except (subprocess.CalledProcessError, subprocess.TimeoutExpired) as e:
                self.logger.error(f"usage-limit Enter send-keys failed: {e}")
                self._transition(State.PAUSED_FOR_HUMAN, reason=f"send-keys failed: {e}")
                return
            self._emit_action(kind="key", text="Enter")
            transition_reason = "rate-limit menu Enter on default"

        wait_min = self.config["policy"].get("usageResetWaitMinutes", 15)
        self.state.usageResetAttempts += 1
        self.state.waitingResetUntil = (
            dt.datetime.now() + dt.timedelta(minutes=wait_min)
        ).isoformat()
        self.logger.info(
            f"usage limited (inline={bool(info.get('inline'))}); waiting until "
            f"{self.state.waitingResetUntil} (attempt {self.state.usageResetAttempts}/{max_attempts})"
        )
        self._transition(State.WAITING_FOR_RESET, reason=transition_reason)

    def _handle_waiting_for_reset(self, classifier: Classifier, normalized: str) -> None:
        if self.state.waitingResetUntil:
            try:
                until = dt.datetime.fromisoformat(self.state.waitingResetUntil)
            except ValueError:
                until = dt.datetime.now()
            if dt.datetime.now() < until:
                self.logger.debug(f"WAITING_FOR_RESET: until {until.isoformat()}")
                return

        max_attempts = int(self.config["policy"].get("maxUsageResetAttempts", 32))
        if classifier == Classifier.USAGE_LIMITED:
            if self.state.usageResetAttempts >= max_attempts:
                self.logger.error("max usage reset attempts exhausted")
                self._transition(State.PAUSED_FOR_HUMAN, reason="usage reset attempts exhausted")
                return
            cont = self.config["commands"].get("continue", "continue")
            self.logger.info(
                f"WAITING_FOR_RESET timeout; usage still limited; sending '{cont}' "
                f"(attempt {self.state.usageResetAttempts + 1}/{max_attempts})"
            )
            self._send_text(cont)
            self.state.usageResetAttempts += 1
            wait_min = self.config["policy"].get("usageResetWaitMinutes", 15)
            self.state.waitingResetUntil = (
                dt.datetime.now() + dt.timedelta(minutes=wait_min)
            ).isoformat()
            return

        self.logger.info("usage block cleared; resuming")
        self.state.waitingResetUntil = None
        self._transition(State.RUNNING, reason="usage block cleared")

    def _try_llm_fallback(self, normalized: str) -> None:
        # Cooldown after recent transient errors (502/503/timeout, etc.) —
        # treat every poll within the cooldown window as "wait" without
        # calling the API. Avoids hammering Anthropic during an outage and
        # avoids stranding the controller in PAUSED_FOR_HUMAN over a blip.
        now_ts = time.time()
        if now_ts < self.llm_error_cooldown_until:
            remain = int(self.llm_error_cooldown_until - now_ts)
            self.logger.debug(f"LLM fallback in cooldown ({remain}s left); treating as wait")
            self._transition(State.RUNNING, reason=f"LLM error cooldown {remain}s — wait")
            return

        cur_hash = screen_hash(normalized)

        # New screen → reset staircase + cache.
        if cur_hash != self.llm_static_hash:
            self.llm_static_hash = cur_hash
            self.llm_static_calls = 0
            self.llm_cache_hash = None
            self.llm_cache_was_wait = False
            self.llm_cache_hits = 0

        # Cache short-circuit. After ESCALATION_POLLS cache hits on the same
        # screen, fall through to a fresh API call with deeper context — gives
        # Haiku another shot at catching something it missed (e.g., a rate-
        # limit menu hidden in scrollback above the small initial window).
        if self.llm_cache_hash == cur_hash and self.llm_cache_was_wait:
            self.llm_cache_hits += 1
            if self.llm_cache_hits < LLM_ESCALATION_POLLS:
                age = time.time() - self.llm_cache_at
                self.logger.debug(
                    f"LLM fallback: cached wait (hash={cur_hash}, hits={self.llm_cache_hits}, age={age:.0f}s)"
                )
                self._transition(State.RUNNING, reason="cached LLM wait — same screen")
                return
            # Escalation tick — drop cache, fall through to fresh call.
            self.llm_cache_hash = None
            self.llm_cache_was_wait = False
            self.llm_cache_hits = 0
            self.logger.info(
                f"LLM fallback: escalating after {LLM_ESCALATION_POLLS} cache hits "
                f"(hash={cur_hash}, level={self.llm_static_calls + 1})"
            )

        # Staircase cap. After LLM_STAIRCASE_LEVELS attempts on a static
        # screen, stay in cached-wait sticky mode rather than burning more
        # API calls. Better to under-react than to bleed money on a screen
        # neither rules nor LLM can resolve.
        if self.llm_static_calls >= len(LLM_STAIRCASE_LEVELS):
            if self.llm_cache_hash != cur_hash or not self.llm_cache_was_wait:
                self.logger.info(
                    f"LLM staircase cap ({len(LLM_STAIRCASE_LEVELS)}) reached on hash {cur_hash}; "
                    f"sticky wait (no further calls until screen changes)"
                )
            self.llm_cache_hash = cur_hash
            self.llm_cache_was_wait = True
            self.llm_cache_at = time.time()
            # Reset hit counter so the cache short-circuit holds for another
            # ESCALATION_POLLS polls. After that window, the escalation tick
            # will drop the cache, the cap check above will catch it again,
            # and we re-enter sticky wait — at most one INFO log every 5 min.
            self.llm_cache_hits = 0
            self._transition(State.RUNNING, reason="LLM staircase cap — sticky wait")
            return

        api_key = os.environ.get("ANTHROPIC_API_KEY")
        if not api_key:
            self.logger.warning("LLM fallback enabled but ANTHROPIC_API_KEY not set; pausing")
            self._transition(State.PAUSED_FOR_HUMAN, reason="LLM fallback unavailable")
            return

        # Capture pane fresh at this level's depth — earlier scrollback may
        # contain context that changes Haiku's verdict (e.g., a rate-limit
        # menu rendered before status footer).
        level_idx = self.llm_static_calls
        level = LLM_STAIRCASE_LEVELS[level_idx]
        try:
            raw = self.tmux.capture_pane(level["capture"])
            staircase_normalized = normalize_screen(raw)
        except (subprocess.CalledProcessError, subprocess.TimeoutExpired) as e:
            self.logger.error(f"LLM fallback pane capture failed: {e}; using polled screen")
            staircase_normalized = normalized
        screen_for_llm = staircase_normalized[-level["chars"]:]
        self.llm_static_calls += 1

        whitelist = self.config["policy"].get("llmFallbackAllowedTexts", [])
        snapshot_id = dt.datetime.now().strftime("%Y%m%dT%H%M%S")
        snapshot_path = self.paths["screens"] / f"{snapshot_id}.txt"
        try:
            snapshot_path.write_text(staircase_normalized)
        except OSError:
            pass

        prompt = (
            "You are a CLI orchestration assistant inspecting one terminal screen.\n"
            "Decide ONE next action.\n\n"
            "Output ONLY a JSON object of the form:\n"
            '{"decision": "send_text" | "wait" | "pause_for_human" | '
            '"usage_limit_menu" | "usage_limit_inline" | "plan" | "execute", '
            '"text": "<required only when decision=send_text; otherwise null>", '
            '"phase": <integer, required only when decision=plan or decision=execute>, '
            '"reason": "<<=200 chars>", "confidence": "high" | "low"}\n\n'
            "Decision semantics:\n"
            "- send_text: respond with a specific allowed text now.\n"
            "- wait: no action needed; the screen will resolve autonomously "
            "(subagents running, async task in progress, parallel worktrees, etc.). "
            "Controller will keep observing — DO NOT use this for human-intervention scenarios.\n"
            "- pause_for_human: a human must intervene (unrecognized prompt, error, "
            "decision genuinely requiring judgment). Controller halts injection.\n"
            "- plan: dispatch a plan-phase major command for the given phase number. "
            "Controller renders the configured plan command and sends /clear + cmd. "
            "Use ONLY when Claude has clearly signalled the previous phase is complete "
            "AND the next phase needs planning (e.g., a 'phase X complete; next phase Y' "
            "summary, or roadmap status showing phase Y next without an existing plan).\n"
            "- execute: dispatch an execute-phase major command for the given phase. "
            "Use ONLY when planning is clearly complete and execution is the next step.\n"
            "- usage_limit_menu: Claude Code is showing the BLOCKING rate-limit menu — "
            "i.e., 'Stop and wait for limit to reset' AND 'Upgrade your plan' visible "
            "as SELECTABLE menu options with cursor (❯ / ▸) on one of them. "
            "Controller presses Enter on default and enters wait/retry loop.\n"
            "- usage_limit_inline: a SUBAGENT hit a HARD usage limit. ONLY fire when "
            "the literal phrase 'hit your limit' appears as inline tool output (a ⎿ "
            "marker block from a completed subagent), e.g.:\n"
            "    ⎿  You've hit your limit · resets 1pm\n"
            "       /upgrade or /extra-usage to finish what you're working on.\n"
            "  This is a HARD-FAILURE rendering — distinct shape from soft warnings.\n"
            "  ❌ DO NOT fire usage_limit_inline for any of these (they are SOFT, "
            "informational, and the controller must NOT send 'continue'):\n"
            "    • 'You've used X% of your session limit ...'\n"
            "    • 'X% used' / 'XX% of weekly limit' / progress-bar text\n"
            "    • '5-hour limit · resets at HH:MM'\n"
            "    • Any percentage-based warning, status footer, or approaching-limit hint\n"
            "  If you are uncertain whether it's a real hit vs a percentage warning, "
            "return 'wait' — never speculate.\n\n"
            "CRITICAL — INPUT-BOX HYGIENE:\n"
            "The input box may contain STAGED text the user or Claude typed but did "
            "NOT submit (e.g., '❯ /gsd-plan-phase 91' sitting unsent). Treat this as "
            "noise, NOT evidence. NEVER:\n"
            "  • dispatch 'plan'/'execute' just because a /gsd-X-phase command is "
            "    staged in the input box;\n"
            "  • return send_text just to 'submit' staged input.\n"
            "Only dispatch plan/execute when Claude's printed OUTPUT clearly states the "
            "phase has completed and which phase is next.\n\n"
            f"Allowed text values for send_text (case-insensitive exact match): {json.dumps(whitelist)}\n"
            "You MAY NOT issue slash commands directly via send_text. You MAY NOT "
            "navigate menus.\n"
            "If the safe action is not unambiguous AND no autonomous resolution is in progress, "
            "return decision=pause_for_human.\n\n"
            f"Controller state: {self.state.state}\n"
            f"Last command sent: {self.state.lastCommandSent!r}\n"
            f"Last phase: {self.state.lastPhase!r}\n"
            f"Staircase level: {level_idx + 1}/{len(LLM_STAIRCASE_LEVELS)} "
            f"(capture={level['capture']} lines, context={level['chars']} chars)\n\n"
            f"Screen (last {level['chars']} chars):\n{screen_for_llm}\n"
        )

        body = {
            "model": "claude-haiku-4-5-20251001",
            "max_tokens": 256,
            "messages": [{"role": "user", "content": prompt}],
        }
        req = urllib.request.Request(
            "https://api.anthropic.com/v1/messages",
            data=json.dumps(body).encode("utf-8"),
            headers={
                "x-api-key": api_key,
                "anthropic-version": "2023-06-01",
                "content-type": "application/json",
            },
        )
        # Retry loop: up to len(LLM_RETRY_BACKOFF)+1 attempts. Transient HTTP
        # codes (502/503/504/408/429/500) and network errors retry with the
        # configured backoff schedule. Non-transient errors (auth, malformed
        # request) pause for human. After retries exhausted, enter cooldown
        # (treat subsequent polls as "wait") rather than pause — the API will
        # likely recover within minutes and we don't want to strand overnight.
        text: str | None = None
        max_attempts = len(LLM_RETRY_BACKOFF) + 1
        for attempt in range(max_attempts):
            try:
                with urllib.request.urlopen(req, timeout=30) as resp:
                    resp_data = json.loads(resp.read())
                text = "".join(p.get("text", "") for p in resp_data.get("content", []))
                break
            except urllib.error.HTTPError as e:
                transient = e.code in LLM_TRANSIENT_HTTP_CODES
                if transient and attempt < len(LLM_RETRY_BACKOFF):
                    backoff = LLM_RETRY_BACKOFF[attempt]
                    self.logger.warning(
                        f"LLM fallback HTTP {e.code} {e.reason} "
                        f"(attempt {attempt + 1}/{max_attempts}); retrying in {backoff}s"
                    )
                    time.sleep(backoff)
                    continue
                # Either non-transient, or retries exhausted.
                if transient:
                    self.logger.error(
                        f"LLM fallback exhausted retries on HTTP {e.code} ({e.reason}); "
                        f"entering {LLM_ERROR_COOLDOWN_SEC}s cooldown"
                    )
                    self.llm_error_cooldown_until = time.time() + LLM_ERROR_COOLDOWN_SEC
                    self._transition(
                        State.RUNNING,
                        reason=f"LLM transient HTTP {e.code} after retries — wait",
                    )
                else:
                    self.logger.error(
                        f"LLM fallback non-transient HTTP {e.code} ({e.reason}); pausing"
                    )
                    self._transition(
                        State.PAUSED_FOR_HUMAN,
                        reason=f"LLM fallback HTTP {e.code}",
                    )
                return
            except (urllib.error.URLError, OSError) as e:
                # Network/timeout/socket error — always treat as transient.
                if attempt < len(LLM_RETRY_BACKOFF):
                    backoff = LLM_RETRY_BACKOFF[attempt]
                    self.logger.warning(
                        f"LLM fallback network error (attempt {attempt + 1}/{max_attempts}): {e}; "
                        f"retrying in {backoff}s"
                    )
                    time.sleep(backoff)
                    continue
                self.logger.error(
                    f"LLM fallback network error after {max_attempts} attempts: {e}; "
                    f"entering {LLM_ERROR_COOLDOWN_SEC}s cooldown"
                )
                self.llm_error_cooldown_until = time.time() + LLM_ERROR_COOLDOWN_SEC
                self._transition(
                    State.RUNNING,
                    reason="LLM network error after retries — wait",
                )
                return
            except ValueError as e:
                # JSON decode error — API gave us garbage. Not retry-worthy.
                self.logger.error(f"LLM fallback bad JSON response: {e}; pausing")
                self._transition(State.PAUSED_FOR_HUMAN, reason="LLM fallback bad JSON")
                return

        if text is None:
            # Defensive — should be unreachable, every loop branch either sets
            # text, returns, or continues.
            self.logger.error("LLM fallback retry loop produced no response; pausing")
            self._transition(State.PAUSED_FOR_HUMAN, reason="LLM fallback empty response")
            return

        self.logger.info(f"LLM fallback raw response: {text!r}")

        decision_obj = None
        try:
            m = re.search(r"\{.*\}", text, re.DOTALL)
            decision_obj = json.loads(m.group(0)) if m else json.loads(text)
        except (json.JSONDecodeError, AttributeError):
            self.logger.warning("LLM fallback returned non-JSON; pausing")
            self._transition(State.PAUSED_FOR_HUMAN, reason="LLM non-JSON response")
            return

        # Schema: decision is required and one of the known values.
        # - text is REQUIRED only for send_text.
        # - phase is REQUIRED (positive int) only for plan/execute.
        # Other decisions ignore both fields.
        decision = decision_obj.get("decision") if isinstance(decision_obj, dict) else None
        valid_decisions = (
            "send_text", "wait", "pause_for_human",
            "usage_limit_menu", "usage_limit_inline",
            "plan", "execute",
        )
        valid = (
            isinstance(decision_obj, dict)
            and decision in valid_decisions
            and isinstance(decision_obj.get("reason", ""), str)
        )
        if valid and decision == "send_text":
            t = decision_obj.get("text")
            valid = isinstance(t, str) and bool(t.strip())
        phase_int: int | None = None
        if valid and decision in ("plan", "execute"):
            p = decision_obj.get("phase")
            if isinstance(p, bool) or not isinstance(p, (int, float)) or p <= 0:
                valid = False
            else:
                phase_int = int(p)
        if not valid:
            self.logger.warning(f"LLM fallback failed schema validation: {decision_obj}")
            self._transition(State.PAUSED_FOR_HUMAN, reason="LLM schema invalid")
            return

        self._emit_event(
            llmFallback={
                "snapshot": str(snapshot_path),
                "raw": text[:500],
                "parsed": decision_obj,
                "level": level_idx + 1,
            }
        )

        if decision == "wait":
            # Autonomous resolution in progress (subagents running, async task,
            # parallel worktrees, etc.). Stay in RUNNING and keep observing —
            # explicitly NOT a human-intervention pause.
            self.logger.info(
                f"LLM advised wait: {decision_obj.get('reason')} "
                f"(confidence={decision_obj.get('confidence')})"
            )
            # Cache this decision so subsequent polls on the same screen skip
            # the API call entirely until ESCALATION_POLLS hits or hash change.
            self.llm_cache_hash = cur_hash
            self.llm_cache_was_wait = True
            self.llm_cache_at = time.time()
            self.llm_cache_hits = 0
            self._transition(State.RUNNING, reason="LLM wait — autonomous resolution")
            return

        if decision == "pause_for_human":
            self.logger.info(f"LLM advised pause: {decision_obj.get('reason')}")
            self._transition(State.PAUSED_FOR_HUMAN, reason="LLM pause_for_human")
            return

        if decision in ("usage_limit_menu", "usage_limit_inline"):
            inline = (decision == "usage_limit_inline")
            self.logger.info(
                f"LLM advised {decision}: {decision_obj.get('reason')} "
                f"(confidence={decision_obj.get('confidence')})"
            )
            # Reset cache + staircase: handing off to the USAGE_LIMITED flow,
            # which manages its own retry timer. We don't want stale cache
            # affecting future fallback calls if the limit clears.
            self.llm_cache_hash = None
            self.llm_cache_was_wait = False
            self.llm_static_calls = 0
            self._transition(
                State.USAGE_LIMITED,
                reason=f"LLM detected rate-limit ({'inline' if inline else 'menu'})",
            )
            self._handle_usage_limited(staircase_normalized, {"inline": inline})
            return

        if decision in ("plan", "execute"):
            # LLM-recommended major command. Same dispatch path the
            # deterministic rules use — _send_major_command handles /clear,
            # template rendering, dedup-guard, and state bookkeeping.
            phase_str = str(phase_int)
            self.logger.info(
                f"LLM dispatched {decision} phase {phase_str}: "
                f"{decision_obj.get('reason')} "
                f"(confidence={decision_obj.get('confidence')})"
            )
            self.state.lastPhase = phase_str
            # Clear cache + staircase since we're acting; screen will change.
            self.llm_cache_hash = None
            self.llm_cache_was_wait = False
            self.llm_static_calls = 0
            if decision == "plan":
                mode = self.config["policy"].get("defaultPlanMode", "without_research")
                tmpl_key = "withResearch" if mode == "with_research" else "withoutResearch"
                tmpl = self.config["commands"]["plan"][tmpl_key]
                prd = self.config["project"].get("prdPath", "")
                skip_verify = bool(self.config["policy"].get("skipPlanVerification", False))
                verify_flag = "--skip-verify" if skip_verify else ""
                self._send_major_command(tmpl, phase=phase_str, prd=prd, verify_flag=verify_flag)
            else:
                tmpl = self.config["commands"]["execute"]["default"]
                self._send_major_command(tmpl, phase=phase_str)
            self._transition(State.RUNNING, reason=f"LLM dispatched {decision} phase {phase_str}")
            return

        # Non-wait decisions (send_text below) imply we acted; the screen
        # should change next poll. Invalidate cache so we re-evaluate fresh.
        self.llm_cache_hash = None
        self.llm_cache_was_wait = False

        proposed = decision_obj.get("text", "")
        canonical = next((w for w in whitelist if proposed.lower() == w.lower()), None)
        if canonical is None:
            self.logger.warning(f"LLM proposed non-whitelisted text {proposed!r}; pausing")
            self._transition(State.PAUSED_FOR_HUMAN, reason="LLM text not in whitelist")
            return

        if canonical != proposed:
            self.logger.info(
                f"LLM fallback canonicalized '{proposed}' -> '{canonical}'"
            )
        self.logger.info(f"LLM fallback approved: '{canonical}' (confidence={decision_obj.get('confidence')})")
        self._send_text(canonical)
        self._transition(State.RUNNING, reason="LLM fallback action sent")


# ---------- Config ----------

def load_config(repo: pathlib.Path) -> dict:
    cfg_path = repo / CONFIG_REL
    if not cfg_path.exists():
        raise SystemExit(
            f"[gsd-auto-v4] config not found: {cfg_path}\n"
            "Run `gsd-auto-v4 init` from the target repo first."
        )
    try:
        return json.loads(cfg_path.read_text())
    except json.JSONDecodeError as e:
        raise SystemExit(f"[gsd-auto-v4] config is not valid JSON: {cfg_path}: {e}")


def validate_config(cfg: dict) -> list[str]:
    errors: list[str] = []
    for top in ("session", "commands", "patterns", "policy"):
        if top not in cfg:
            errors.append(f"missing top-level key: {top}")

    sess = cfg.get("session", {})
    for k in ("tmuxSessionName", "claudeLaunchCommand", "paneCaptureLines",
              "pollIntervalSeconds", "idleStabilityPolls"):
        if k not in sess:
            errors.append(f"session.{k} missing")

    cmds = cfg.get("commands", {})
    if "execute" not in cmds or "default" not in cmds.get("execute", {}):
        errors.append("commands.execute.default missing")
    if "plan" not in cmds or "withoutResearch" not in cmds.get("plan", {}):
        errors.append("commands.plan.withoutResearch missing")

    pol = cfg.get("policy", {})
    if pol.get("defaultPlanMode") not in ("with_research", "without_research", None):
        errors.append("policy.defaultPlanMode must be with_research or without_research")
    if "skipPlanVerification" in pol and not isinstance(pol["skipPlanVerification"], bool):
        errors.append("policy.skipPlanVerification must be a boolean")

    if "model" in sess:
        v = sess["model"]
        if not isinstance(v, str) or not v.strip():
            errors.append("session.model must be a non-empty string (e.g. 'default' or 'claude-opus-4-6[1m]')")

    if "heartbeatIntervalSeconds" in sess:
        v = sess["heartbeatIntervalSeconds"]
        if not isinstance(v, (int, float)) or v <= 0:
            errors.append("session.heartbeatIntervalSeconds must be a positive number")

    return errors


def is_pid_alive(pid: int) -> bool:
    if pid <= 0:
        return False
    try:
        os.kill(pid, 0)
        return True
    except ProcessLookupError:
        return False
    except PermissionError:
        return True
    except OSError:
        return False


def session_name_for(repo: pathlib.Path, cfg: dict) -> str:
    return cfg["session"]["tmuxSessionName"].replace("{project}", repo.name)


def claude_startup_commands(session: str) -> list[str]:
    session_arg = shlex.quote(session)
    return [f"{cmd} {session_arg}" for cmd in CLAUDE_STARTUP_COMMANDS]


def planning_command_preview(repo: pathlib.Path, cfg: dict) -> tuple[str, str]:
    mode = cfg["policy"].get("defaultPlanMode", "without_research")
    tmpl_key = "withResearch" if mode == "with_research" else "withoutResearch"
    tmpl = cfg["commands"]["plan"][tmpl_key]
    prd = cfg.get("project", {}).get("prdPath", "")
    skip_verify = bool(cfg["policy"].get("skipPlanVerification", False))
    verify_flag = "--skip-verify" if skip_verify else ""
    command = render_command(
        tmpl,
        phase=PLANNING_PHASE_PLACEHOLDER,
        prd=prd,
        project=repo.name,
        verify_flag=verify_flag,
    )
    return tmpl_key, command


def setup_observer_panes(tmux: Tmux, repo: pathlib.Path, cfg: dict) -> None:
    tail_command = f"{shlex.quote(str(SCRIPT_PATH))} tail -f"
    log_pane = tmux.split_window(
        target=tmux.main_pane(),
        cwd=repo,
        command=tail_command,
        percent=25,
    )

    tmpl_key, command = planning_command_preview(repo, cfg)
    preview_text = (
        "Planning command preview\n"
        f"Config key: commands.plan.{tmpl_key}\n"
        f"Phase placeholder: {PLANNING_PHASE_PLACEHOLDER}\n"
        "\n"
        f"{command}\n"
    )
    preview_command = f"printf '%s' {shlex.quote(preview_text)}; exec \"${{SHELL:-/bin/sh}}\""
    tmux.split_window(
        target=log_pane,
        cwd=repo,
        command=preview_command,
        horizontal=True,
        percent=35,
    )
    tmux.select_main_pane()


# ---------- CLI commands ----------

CLAUDE_MD_BEGIN = "<!-- gsd-auto:begin -->"
CLAUDE_MD_END = "<!-- gsd-auto:end -->"

CLAUDE_MD_DIRECTIVES = """\
# gsd-auto runtime directives

This project is being driven by **gsd-auto-v4**, an automated terminal controller. Until you see this block removed, behave as follows so the controller can run unattended:

- **Defer all UAT and manual verification to end of milestone.** When a workflow step asks for "manual UAT", "please test", "please confirm", "verification required", or any equivalent runtime confirmation, **respond by deferring** — record the deferral in the artifact (e.g. STATE.md / VERIFICATION.md "Deferred Items"), continue the workflow, and let the milestone close-out collect them. Do not block phase progression on UAT.
- **Do not ask the operator for confirmation on routine decisions.** If a sensible default exists, take it and note it in the relevant artifact. Save questions for genuinely ambiguous calls.
- **Avoid spawning interactive TUI menus during phase execution.** Plan-phase already runs with `--text` (plain numbered prompts). For execute-phase and other workflows, prefer plain-text prompts the controller's LLM-fallback whitelist can answer (`continue`, `y`, `n`, `defer to end of milestone verification`, `approve`, `fix the bug now`).
- **Treat usage-limit warnings as informational, not blocking.** Approaching/inline limit warnings should not pause work. The controller handles the actual blocking rate-limit menu (Stop and wait + 15-min retry loop) on its own.
- **Stop the workflow when you genuinely need a human.** If a decision truly requires the operator (architectural fork, security review, irreversible destructive op), pause and surface the decision clearly — the controller will route it via PAUSED_FOR_HUMAN. Do not invent an answer.
"""


def _ensure_claude_md_directives(repo: pathlib.Path) -> None:
    """Inject (or refresh) the gsd-auto directive block at the top of CLAUDE.md.

    Idempotent: re-running init replaces the existing managed block in place
    without disturbing the rest of the file. The block is bounded by HTML
    comment markers so users can find/edit/delete it manually if needed.
    """
    claude_md = repo / "CLAUDE.md"
    block = f"{CLAUDE_MD_BEGIN}\n{CLAUDE_MD_DIRECTIVES}{CLAUDE_MD_END}\n"

    if not claude_md.exists():
        claude_md.write_text(block)
        print(f"[gsd-auto-v4] created {claude_md} with gsd-auto directives")
        return

    existing = claude_md.read_text()
    if CLAUDE_MD_BEGIN in existing and CLAUDE_MD_END in existing:
        # Replace existing managed block in place.
        pattern = re.compile(
            re.escape(CLAUDE_MD_BEGIN) + r".*?" + re.escape(CLAUDE_MD_END) + r"\n?",
            re.DOTALL,
        )
        new_text = pattern.sub(block, existing, count=1)
        if new_text != existing:
            claude_md.write_text(new_text)
            print(f"[gsd-auto-v4] refreshed gsd-auto directives in {claude_md}")
        else:
            print(f"[gsd-auto-v4] gsd-auto directives in {claude_md} already up to date")
    else:
        # Prepend the block at the top, preserving everything below.
        if existing and not existing.endswith("\n"):
            existing += "\n"
        claude_md.write_text(block + "\n" + existing)
        print(f"[gsd-auto-v4] prepended gsd-auto directives to {claude_md}")


def cmd_init(_args) -> None:
    repo = pathlib.Path.cwd()
    cfg_dir = repo / "gsd-auto"
    cfg_dir.mkdir(exist_ok=True)
    (cfg_dir / "runtime").mkdir(exist_ok=True)
    (cfg_dir / "runtime" / "screens").mkdir(exist_ok=True)

    target = cfg_dir / "config.json"
    if target.exists():
        print(f"[gsd-auto-v4] config already exists: {target}")
    else:
        if not TEMPLATE_CONFIG.exists():
            print(f"[gsd-auto-v4] template not found: {TEMPLATE_CONFIG}", file=sys.stderr)
            sys.exit(1)
        shutil.copy(TEMPLATE_CONFIG, target)
        print(f"[gsd-auto-v4] wrote {target}")

    gitignore = repo / ".gitignore"
    line = "gsd-auto/runtime/"
    if gitignore.exists():
        existing = gitignore.read_text()
        if line not in existing.splitlines():
            with gitignore.open("a") as f:
                if existing and not existing.endswith("\n"):
                    f.write("\n")
                f.write(line + "\n")
            print(f"[gsd-auto-v4] added {line} to .gitignore")
    else:
        gitignore.write_text(line + "\n")
        print(f"[gsd-auto-v4] created .gitignore with {line}")

    _ensure_claude_md_directives(repo)

    print(f"[gsd-auto-v4] init complete: {cfg_dir}")
    print("Next: edit gsd-auto/config.json if needed, then `gsd-auto-v4 run`.")


def cmd_run(_args) -> None:
    repo = pathlib.Path.cwd()
    cfg = load_config(repo)
    errs = validate_config(cfg)
    if errs:
        for e in errs:
            print(f"[gsd-auto-v4] config error: {e}", file=sys.stderr)
        sys.exit(1)

    paths = runtime_paths(repo)
    paths["root"].mkdir(parents=True, exist_ok=True)
    paths["screens"].mkdir(parents=True, exist_ok=True)

    if shutil.which("tmux") is None:
        print("[gsd-auto-v4] tmux not found in PATH", file=sys.stderr)
        sys.exit(1)

    session = session_name_for(repo, cfg)

    if paths["pid"].exists():
        try:
            pid_text = paths["pid"].read_text().strip()
            existing = int(pid_text) if pid_text else 0
        except (ValueError, OSError):
            existing = 0
        if existing and is_pid_alive(existing):
            print(f"[gsd-auto-v4] controller already running (PID {existing})")
            print(f"[gsd-auto-v4] attaching to tmux session {session}")
            os.execvp("tmux", ["tmux", "attach", "-t", session])
        else:
            try:
                paths["pid"].unlink()
            except FileNotFoundError:
                pass

    tmux = Tmux(session)
    try:
        if not tmux.has_session():
            print(f"[gsd-auto-v4] creating tmux session: {session}")
            tmux.new_session()
            time.sleep(0.5)
            launch = cfg["session"]["claudeLaunchCommand"]
            model = cfg["session"].get("model", "default")
            launch = launch.replace("{model}", model)
            print(f"[gsd-auto-v4] launching Claude: {launch}")
            tmux.send_text_enter(launch)
            time.sleep(CLAUDE_STARTUP_DELAY_SECONDS)
            for startup_command in claude_startup_commands(session):
                print(f"[gsd-auto-v4] running Claude startup command: {startup_command}")
                tmux.send_text_enter(startup_command)
                time.sleep(CLAUDE_STARTUP_COMMAND_DELAY_SECONDS)
            print("[gsd-auto-v4] creating observer panes")
            setup_observer_panes(tmux, repo, cfg)
        else:
            print(f"[gsd-auto-v4] tmux session exists: {session}")
    except (subprocess.CalledProcessError, subprocess.TimeoutExpired) as e:
        print(f"[gsd-auto-v4] tmux startup failed: {e}", file=sys.stderr)
        sys.exit(1)

    print("[gsd-auto-v4] starting controller loop in background")
    # Capture stderr to a file so config/import errors that fire before the
    # logger is set up are still diagnosable.
    stderr_log_path = paths["root"] / "loop-stderr.log"
    stderr_log = open(stderr_log_path, "a")
    child = subprocess.Popen(
        [sys.executable, str(SCRIPT_PATH), "_loop"],
        cwd=str(repo),
        stdout=subprocess.DEVNULL,
        stderr=stderr_log,
        stdin=subprocess.DEVNULL,
        start_new_session=True,
    )
    stderr_log.close()
    paths["pid"].write_text(str(child.pid))
    print(f"[gsd-auto-v4] controller PID {child.pid}")
    print(f"[gsd-auto-v4] log: {paths['log']}")
    print(f"[gsd-auto-v4] stderr: {stderr_log_path}")
    print(f"[gsd-auto-v4] attaching to tmux (Ctrl-b d to detach; controller keeps running)")
    time.sleep(0.5)
    os.execvp("tmux", ["tmux", "attach", "-t", session])


def cmd_loop(_args) -> None:
    repo = pathlib.Path.cwd()
    cfg = load_config(repo)
    paths = runtime_paths(repo)
    paths["root"].mkdir(parents=True, exist_ok=True)
    paths["screens"].mkdir(parents=True, exist_ok=True)
    Controller(repo, cfg).run()


def cmd_attach(_args) -> None:
    repo = pathlib.Path.cwd()
    cfg = load_config(repo)
    session = session_name_for(repo, cfg)
    os.execvp("tmux", ["tmux", "attach", "-t", session])


def cmd_status(_args) -> None:
    repo = pathlib.Path.cwd()
    paths = runtime_paths(repo)
    if not paths["state"].exists():
        print("[gsd-auto-v4] no state file; controller has not run in this repo")
        return
    try:
        state = json.loads(paths["state"].read_text())
    except (json.JSONDecodeError, OSError):
        print("[gsd-auto-v4] state file unreadable")
        return

    pid = None
    alive = False
    if paths["pid"].exists():
        try:
            pid = int(paths["pid"].read_text().strip())
            alive = is_pid_alive(pid)
        except (ValueError, OSError):
            pass

    last_change_age = "?"
    ts = state.get("lastActionTimestamp")
    if ts:
        try:
            then = dt.datetime.fromisoformat(ts)
            last_change_age = f"{int((dt.datetime.now() - then).total_seconds())}s ago"
        except ValueError:
            pass

    print(f"controller PID:    {pid} ({'alive' if alive else 'dead'})")
    print(f"state:             {state.get('state')}")
    print(f"observed first:    {state.get('hasObservedFirstCycle')}")
    print(f"last phase:        {state.get('lastPhase')}")
    print(f"last command:      {state.get('lastCommandSent')}")
    print(f"last action:       {last_change_age}")
    print(f"poll count:        {state.get('pollCount')}")
    print(f"screen hash:       {state.get('screenHash')}")
    print(f"stable count:      {state.get('stableCount')}")
    print(f"reset attempts:    {state.get('usageResetAttempts')}")
    print(f"waiting until:     {state.get('waitingResetUntil')}")
    print(f"retry counts:      {state.get('retryCounts')}")
    flags = []
    if paths["pause_flag"].exists():
        flags.append("PAUSED")
    if paths["stop_next_flag"].exists():
        flags.append("STOP-NEXT")
    print(f"flags:             {', '.join(flags) if flags else '(none)'}")


def cmd_pause(_args) -> None:
    paths = runtime_paths(pathlib.Path.cwd())
    paths["root"].mkdir(parents=True, exist_ok=True)
    paths["pause_flag"].touch()
    print(f"[gsd-auto-v4] paused (flag: {paths['pause_flag']})")
    print("Run `gsd-auto-v4 resume` to re-enable action injection.")


def cmd_resume(_args) -> None:
    paths = runtime_paths(pathlib.Path.cwd())
    try:
        paths["pause_flag"].unlink()
    except FileNotFoundError:
        pass
    print("[gsd-auto-v4] resumed")


def cmd_stop_next(_args) -> None:
    paths = runtime_paths(pathlib.Path.cwd())
    paths["root"].mkdir(parents=True, exist_ok=True)
    paths["stop_next_flag"].touch()
    print(f"[gsd-auto-v4] stop-next set (flag: {paths['stop_next_flag']})")
    print("The controller will transition to COMPLETE before injecting another major command.")


def kill_controller_process(paths: dict[str, pathlib.Path]) -> bool:
    if paths["pid"].exists():
        try:
            pid = int(paths["pid"].read_text().strip())
        except (ValueError, OSError):
            pid = 0
        if pid > 0 and is_pid_alive(pid):
            try:
                os.kill(pid, signal.SIGTERM)
            except ProcessLookupError:
                pass
            for _ in range(20):
                if not is_pid_alive(pid):
                    break
                time.sleep(0.1)
            if is_pid_alive(pid):
                try:
                    os.kill(pid, signal.SIGKILL)
                except ProcessLookupError:
                    pass
            print(f"[gsd-auto-v4] killed controller (PID {pid})")
            killed_controller = True
        else:
            print(f"[gsd-auto-v4] no live controller for PID file (stale)")
            killed_controller = False
        try:
            paths["pid"].unlink()
        except FileNotFoundError:
            pass
    else:
        print("[gsd-auto-v4] no controller PID file")
        killed_controller = False
    return killed_controller


def cmd_kill_controller(_args) -> None:
    paths = runtime_paths(pathlib.Path.cwd())
    if not kill_controller_process(paths):
        print("[gsd-auto-v4] no controller process killed")


def cmd_restart(args) -> None:
    """Hot-restart the controller while keeping tmux + Claude alive.

    Use this after editing the script or config: kills only the controller
    process, then re-runs cmd_run which detects the existing tmux session,
    skips Claude relaunch, and spawns a new controller loop. Claude's chat
    context is preserved.
    """
    paths = runtime_paths(pathlib.Path.cwd())
    if kill_controller_process(paths):
        time.sleep(1)
    cmd_run(args)


def cmd_kill(_args) -> None:
    repo = pathlib.Path.cwd()
    paths = runtime_paths(repo)

    killed_controller = kill_controller_process(paths)

    killed_session = False
    try:
        cfg = load_config(repo)
        session = session_name_for(repo, cfg)
    except (FileNotFoundError, ValueError) as e:
        print(f"[gsd-auto-v4] cannot resolve session name: {e}")
        session = None
    if session:
        tmux = Tmux(session)
        if tmux.has_session():
            subprocess.run(
                ["tmux", "kill-session", "-t", session],
                check=False,
            )
            print(f"[gsd-auto-v4] killed tmux session: {session}")
            killed_session = True
        else:
            print(f"[gsd-auto-v4] no tmux session: {session}")

    if not killed_controller and not killed_session:
        print("[gsd-auto-v4] nothing to kill")


def cmd_tail(args) -> None:
    paths = runtime_paths(pathlib.Path.cwd())
    log = paths["log"]
    if args.follow:
        paths["root"].mkdir(parents=True, exist_ok=True)
        log.touch(exist_ok=True)
        os.execvp("tail", ["tail", "-F", str(log)])
    if not log.exists():
        print(f"[gsd-auto-v4] log not found: {log}")
        return
    os.execvp("tail", ["tail", "-n", str(args.lines), str(log)])


def cmd_doctor(_args) -> None:
    repo = pathlib.Path.cwd()
    issues: list[str] = []

    if shutil.which("tmux") is None:
        issues.append("tmux not found in PATH")
    else:
        print("[ok] tmux available")

    cfg_path = repo / CONFIG_REL
    cfg = None
    if not cfg_path.exists():
        issues.append(f"config missing: {cfg_path} (run `gsd-auto-v4 init`)")
    else:
        try:
            cfg = json.loads(cfg_path.read_text())
        except json.JSONDecodeError as e:
            issues.append(f"config not valid JSON: {e}")
        else:
            errs = validate_config(cfg)
            if errs:
                for e in errs:
                    issues.append(f"config: {e}")
            else:
                print(f"[ok] config valid: {cfg_path}")
                project = repo.name
                prd = cfg["project"].get("prdPath", "") if "project" in cfg else ""
                phase = "00.0"
                skip_verify = bool(cfg.get("policy", {}).get("skipPlanVerification", False))
                verify_flag = "--skip-verify" if skip_verify else ""
                templates = []
                if "plan" in cfg["commands"]:
                    if "withResearch" in cfg["commands"]["plan"]:
                        templates.append(("plan.withResearch", cfg["commands"]["plan"]["withResearch"]))
                    if "withoutResearch" in cfg["commands"]["plan"]:
                        templates.append(("plan.withoutResearch", cfg["commands"]["plan"]["withoutResearch"]))
                if "execute" in cfg["commands"]:
                    if "default" in cfg["commands"]["execute"]:
                        templates.append(("execute.default", cfg["commands"]["execute"]["default"]))
                for label, tmpl in templates:
                    rendered = render_command(tmpl, phase=phase, prd=prd,
                                              project=project, verify_flag=verify_flag)
                    print(f"[ok] template {label}: {rendered}")
                print(f"[info] skipPlanVerification: {skip_verify}")
                model = cfg.get("session", {}).get("model", "default")
                launch_preview = cfg["session"]["claudeLaunchCommand"].replace("{model}", model)
                print(f"[info] model: {model}")
                print(f"[info] launch command: {launch_preview}")
                if shutil.which("tmux"):
                    session = session_name_for(repo, cfg)
                    if Tmux(session).has_session():
                        print(f"[ok] tmux session exists: {session}")
                    else:
                        print(f"[info] tmux session does not exist yet: {session}")

    paths = runtime_paths(repo)
    try:
        paths["root"].mkdir(parents=True, exist_ok=True)
        test = paths["root"] / ".doctor"
        test.write_text("ok")
        test.unlink()
        print(f"[ok] runtime dir writable: {paths['root']}")
    except OSError as e:
        issues.append(f"runtime dir not writable: {e}")

    if not TEMPLATE_CONFIG.exists():
        issues.append(f"init template missing: {TEMPLATE_CONFIG}")
    else:
        print(f"[ok] init template present: {TEMPLATE_CONFIG}")

    if issues:
        print("\nIssues:")
        for i in issues:
            print(f"  - {i}")
        sys.exit(1)
    print("\n[ok] all checks passed")


def main() -> None:
    p = argparse.ArgumentParser(
        prog="gsd-auto-v4",
        description="Terminal-native automation controller for GSD workflows.",
    )
    sub = p.add_subparsers(dest="cmd", required=True)
    sub.add_parser("init", help="Initialize gsd-auto config in current repo")
    sub.add_parser("run", help="Start or resume controller and attach to tmux session")
    sub.add_parser("attach", help="Attach to the tmux session")
    sub.add_parser("status", help="Show controller status")
    sub.add_parser("pause", help="Pause action injection")
    sub.add_parser("resume", help="Resume action injection")
    sub.add_parser("stop-next", help="Allow current task to finish, then COMPLETE")
    sub.add_parser("kill-controller", help="Hard-kill controller process only")
    sub.add_parser("kill", help="Hard-kill controller process and tmux session")
    sub.add_parser("restart", help="Hot-restart controller, keep tmux session alive")

    pt = sub.add_parser("tail", help="Tail controller log")
    pt.add_argument("-f", "--follow", action="store_true", help="Follow new log lines")
    pt.add_argument("-n", "--lines", type=int, default=200, help="Number of trailing lines")

    sub.add_parser("doctor", help="Validate environment and config")
    sub.add_parser("_loop", help=argparse.SUPPRESS)

    args = p.parse_args()
    dispatch = {
        "init": cmd_init,
        "run": cmd_run,
        "attach": cmd_attach,
        "status": cmd_status,
        "pause": cmd_pause,
        "resume": cmd_resume,
        "stop-next": cmd_stop_next,
        "kill-controller": cmd_kill_controller,
        "kill": cmd_kill,
        "restart": cmd_restart,
        "tail": cmd_tail,
        "doctor": cmd_doctor,
        "_loop": cmd_loop,
    }
    dispatch[args.cmd](args)


if __name__ == "__main__":
    main()
