TMUX_TIMEOUT_SECONDS = 5
CLAUDE_STARTUP_DELAY_SECONDS = 5
CLAUDE_STARTUP_COMMAND_DELAY_SECONDS = 2
CLAUDE_STARTUP_COMMANDS = ("/rename", "/remote-control")
PLANNING_PHASE_PLACEHOLDER = "<phase>"

# Defaults for session.* values that are read once at controller start.
DEFAULT_CLEAR_TO_MAJOR_DELAY = 1.5
DEFAULT_MAX_IDENTICAL_MAJOR = 2
DEFAULT_INPUT_BOX_SCAN_LINES = 12
DEFAULT_BUSY_MARKER_SCAN_LINES = 30
DEFAULT_MENU_MAX_NAV_STEPS = 40
DEFAULT_MENU_KEY_DELAY = 0.1

# LLM fallback staircase: at most LLM_STAIRCASE_LEVELS API calls per static-
# screen hash. Each level captures more pane lines and sends more context to
# Haiku. Between calls, cache hits up to LLM_ESCALATION_POLLS times before
# escalating. At ~5s/poll, 60 polls ≈ 5 minutes — long enough to be
# meaningful, short enough to react to a stuck screen.
LLM_STAIRCASE_LEVELS = [
    {"capture": 250, "chars": 4000},
    {"capture": 500, "chars": 8000},
    {"capture": 1000, "chars": 16000},
]
LLM_ESCALATION_POLLS = 60

# Transient HTTP status codes that warrant in-call retry rather than pausing
# the controller. Anthropic's API returns 502/503/504 during brief outages
# and 429 when we momentarily over-consume; both clear within seconds-minutes.
LLM_TRANSIENT_HTTP_CODES = (408, 429, 500, 502, 503, 504)
# In-call retry schedule (seconds between attempts). Total max blocking
# time per call: ~17s. After exhaustion, controller enters cooldown.
LLM_RETRY_BACKOFF = (2, 5, 10)
# Cooldown after exhausted retries — every poll within this window short-
# circuits to RUNNING ("treat as wait") without an API call. 2 min keeps the
# duty cycle <10% during a long Anthropic outage while still recovering
# quickly when service comes back.
LLM_ERROR_COOLDOWN_SEC = 120


def runtime_paths(repo: pathlib.Path) -> dict[str, pathlib.Path]:
    rt = repo / RUNTIME_REL
    return {
        "root": rt,
        "screens": rt / "screens",
        "pid": rt / "controller.pid",
        "state": rt / "state.json",
        "events": rt / "events.jsonl",
        "actions": rt / "actions.jsonl",
        "log": rt / "controller.log",
        "raw": rt / "last-screen.txt",
        "norm": rt / "last-screen.normalized.txt",
